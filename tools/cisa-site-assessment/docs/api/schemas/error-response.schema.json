{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://psa-tool.com/schemas/error-response.json",
  "title": "Error Response",
  "description": "Schema for error responses from all endpoints",
  "type": "object",
  "required": ["error"],
  "properties": {
    "error": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable error message"
    },
    "details": {
      "type": ["string", "null"],
      "description": "Additional error details (optional)"
    }
  },
  "additionalProperties": true
}
