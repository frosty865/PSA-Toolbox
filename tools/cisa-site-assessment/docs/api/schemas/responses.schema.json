{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://psa-tool.com/schemas/responses.json",
  "title": "Assessment Responses",
  "description": "Schema for GET /api/assessments/[assessmentId]/responses response",
  "type": "object",
  "required": ["responses"],
  "properties": {
    "responses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["assessment_id", "element_id", "response", "updated_at"],
        "properties": {
          "assessment_id": {
            "type": "string",
            "format": "uuid"
          },
          "element_id": {
            "type": "string",
            "format": "uuid"
          },
          "response": {
            "type": "string",
            "enum": ["YES", "NO", "N/A"]
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
