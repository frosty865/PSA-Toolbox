{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://psa-tool.com/schemas/assessment-list.json",
  "title": "Assessment List",
  "description": "Schema for GET /api/assessments response",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["assessment_id"],
    "properties": {
      "assessment_id": {
        "type": "string",
        "format": "uuid"
      },
      "facility_name": {
        "type": ["string", "null"]
      },
      "sector": {
        "type": ["string", "null"]
      },
      "subsector": {
        "type": ["string", "null"]
      },
      "created_at": {
        "type": ["string", "null"],
        "format": "date-time"
      },
      "updated_at": {
        "type": ["string", "null"],
        "format": "date-time"
      }
    },
    "additionalProperties": false
  }
}
