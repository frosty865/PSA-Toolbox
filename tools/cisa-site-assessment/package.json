{
  "name": "psa-rebuild",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "dev": "npx next dev --port 3001 --webpack",
    "corpus:module-standards": "node scripts/run_corpus_module_standards.js",
    "doctrine:check": "node scripts/check_doctrine_mirrors.js",
    "guard:baseline": "node scripts/guards/verifyNoLegacyBaselineRefs.js .",
    "guard:content": "node scripts/guards/verifyNoLegacyDocumentWrites.js .",
    "guard:no-client-storage-imports": "node scripts/guards/verifyNoClientImportsStorageConfig.js",
    "guard:ofc-extraction": "node scripts/guards/verifyNoDirectOFCExtraction.js",
    "guard:ofc_doctrine": "node scripts/guards/verifyNoAutoMinedOfcRefs.js",
    "guard:ofc-text": "node scripts/guards/verify_ofc_text_rules.js",
    "guard:intake": "node scripts/guards/verifyNoLegacyIntakeRefs.js",
    "guard:db-ownership": "node scripts/guards/verifyDbOwnershipMatchesReality.js",
    "guard:legacy-intent-ui": "node scripts/guards/verifyNoLegacyIntentUI.js .",
    "guard:no-legacy-intent": "node scripts/guards/verifyNoLegacyIntentRefs.js .",
    "guard:runtime-questions-shape": "node scripts/guards/verifyRuntimeQuestionsShape.js",
    "guard:no-empty-ref-impl": "node scripts/guards/verifyNoEmptyReferenceImpl.js",
    "guard:corpus": "node scripts/guards/verifyNoCorpusCanonicalSourcesRef.js",
    "guard:runtime-direct": "npx tsx tools/assert_runtime_direct.ts",
    "guard:db-tls-flags": "npx tsx tools/assert_db_tls_flags.ts",
    "guard:module-templates": "node scripts/guards/verifyModuleTemplatesExist.js",
    "guard:no-scenario-context": "node scripts/guards/verifyNoScenarioContextUI.js",
    "guard:standard-seed": "npx tsx scripts/guards/validate_standard_seed.ts",
    "guard:no-module-attributes": "node scripts/guards/verifyNoModuleAttributes.js",
    "guard:no-promote-to-corpus": "node scripts/guards/verifyNoPromoteToCorpus.js",
    "guard:doctrine-lock": "npx tsx tools/guards/verify_doctrine_lock.ts",
    "guard:ofc-write-origin": "npx tsx tools/guards/verify_no_corpus_ofc_writes.ts",
    "guard:ofc-attachment": "npx tsx tools/guards/verify_ofc_attachment_gating.ts",
    "audit:build-load": "node scripts/audits/build_load_audit.js",
    "test:contracts": "npx tsx scripts/tests/runtimeQuestionsContract.test.ts",
    "test:module-create": "npx tsx scripts/tests/moduleCreateAutomation.test.ts",
    "test:crawler": "node --import tsx --test app/lib/crawler/__tests__/urlCanonicalize.test.ts app/lib/crawler/__tests__/domainTrust.test.ts app/lib/crawler/__tests__/relevanceScore.test.ts app/lib/crawler/__tests__/pdfVerify.test.ts",
    "test:generation-smoke": "npx tsx tools/tests/generation_smoke_test.ts",
    "test:plan-schema": "node --import tsx --test app/lib/modules/plan_ecosystem/__tests__/derive_plan_schema.test.ts app/lib/modules/plan_ecosystem/__tests__/validate_derived_schema.test.ts app/lib/modules/plan_ecosystem/__tests__/extract_plan_toc.test.ts app/lib/modules/plan_ecosystem/__tests__/toc_parse.test.ts app/lib/modules/plan_ecosystem/__tests__/toc_truncation.test.ts app/lib/modules/plan_ecosystem/__tests__/section_intents.test.ts app/lib/modules/plan_ecosystem/__tests__/generate_from_derived_schema.test.ts",
    "test:standards-quality": "npx tsx tools/tests/standards_quality_test.ts",
    "report:ofc-coverage": "node scripts/get_python_path.js scripts/reports/ofc_coverage_snapshot.py",
    "report:ofc-audit": "node scripts/get_python_path.js scripts/reports/ofc_link_audit.py",
    "build": "npm run guard:doctrine-lock && npm run guard:baseline && npm run guard:content && npm run guard:no-client-storage-imports && npm run guard:ofc-extraction && npm run guard:ofc-text && npm run guard:db-ownership && npm run guard:legacy-intent-ui && npm run guard:no-legacy-intent && npm run guard:no-empty-ref-impl && npm run test:contracts && npm run guard:runtime-questions-shape && npx next build --webpack",
    "build:full": "npm run guard:ofc_doctrine && npm run test:module-create && npm run build",
    "start": "npx next start",
    "lint": "eslint app --max-warnings 0",
    "lint_summarize": "npx tsx scripts/lint_summarize.ts",
    "typecheck": "tsc --noEmit",
    "verify:api-surface": "npx tsx scripts/verify_api_surface.ts",
    "baseline:coverage": "npx tsx tools/baseline_coverage_report.ts",
    "validate:subtype-guidance": "npx tsx tools/validate_subtype_guidance.ts",
    "validate:guidance:threshold": "npx tsx tools/validate_subtype_guidance.ts --mode=threshold --threshold=0.95",
    "validate:guidance:strict": "npx tsx tools/validate_subtype_guidance.ts --mode=threshold --threshold=0.98",
    "validate:guidance:explicit": "npx tsx tools/validate_subtype_guidance.ts --mode=explicit",
    "apply:guidance-required": "npx tsx tools/apply_guidance_required_flags.ts",
    "generate:intent": "npx tsx tools/generate_intent_objects.ts",
    "validate:intent": "npx tsx tools/validate_intent_objects.ts",
    "ci:intent": "npm run generate:intent && npm run validate:intent",
    "guard:baseline-text": "npx tsx tools/guards/baseline_text_freeze_guard.ts",
    "snapshot:baseline-text": "BASELINE_TEXT_OVERRIDE=true npx tsx tools/guards/baseline_text_freeze_guard.ts --write-snapshot",
    "guard:depth2-intent": "npx tsx tools/guards/depth2_requires_intent_guard.ts",
    "guard:typed-diff": "npx tsx tools/guards/verify_typed_access_changed.ts",
    "guard:typed-all": "npx tsx tools/guards/verify_typed_access_changed.ts --all",
    "ci:baseline": "npm run guard:baseline-text && npm run ci:intent && npm run guard:depth2-intent",
    "test:routes-smoke": "npx tsx tools/tests/routes_smoke_test.ts",
    "test:admin-security": "node --import tsx --test app/lib/admin/__tests__/audit.test.ts app/lib/admin/__tests__/expansionProfiles.test.ts app/lib/admin/__tests__/serverTools.test.ts app/__tests__/middleware.test.ts",
    "test:pages-smoke": "npx tsx tools/tests/pages_smoke_test.ts",
    "ci:fast-fail": "npm run guard:typed-diff && npm run typecheck && npm run test:admin-security && npm run test:routes-smoke && npm run test:pages-smoke && npm run test:standards-quality",
    "generate:checklists": "npx tsx tools/generate_subtype_checklists.ts",
    "validate:checklists": "npx tsx tools/validate_checklists.ts",
    "generate:depth2-tags": "npx tsx tools/tag_depth2_questions.ts",
    "validate:depth2-tags": "npx tsx tools/validate_depth2_tags.ts",
    "build:branching": "npm run generate:checklists && npm run validate:checklists && npm run generate:depth2-tags && npm run validate:depth2-tags",
    "generate:questions-doc": "npx tsx tools/generate_questions_by_discipline_subtype.ts",
    "build:interaction-map": "npx tsx tools/build_subtype_interaction_map.ts",
    "check:overlay-wiring": "npx tsx tools/check_overlay_wiring.ts",
    "db:overlay-spines:migrate": "npx tsx tools/run_sql.ts tools/sql/create_overlay_spines_runtime.sql",
    "db:audit": "npx tsx tools/db/audit_pools.ts",
    "db:pool-diff": "npx tsx tools/db/pool_diff.ts",
    "db:pool-cleanup-sql": "npx tsx tools/db/generate_pool_cleanup_sql.ts",
    "db:authoritative-cleanup-sql": "npx tsx tools/db/generate_authoritative_cleanup_sql.ts",
    "db:legacy-audit": "npx tsx tools/db/audit_legacy_v1_tables.ts",
    "diag:citations": "npx tsx tools/diagnostics/diagnose_standard_generate_citations.ts",
    "db:legacy-quarantine-sql": "npx tsx tools/db/generate_quarantine_sql.ts",
    "targets:baseline": "npx tsx tools/corpus/build_candidate_targets_baseline.ts",
    "corpus:reprocess-worker": "npx tsx tools/corpus/reprocess_worker.ts",
    "quality": "npm run doctrine:check && npm run lint && npm run typecheck",
    "workspace:cleanup:dry": "npx tsx tools/workspace_cleanup.ts --dry-run",
    "workspace:cleanup:apply": "npx tsx tools/workspace_cleanup.ts --apply",
    "migrate:source-registry": "node scripts/run_migration.js db/migrations/20260116_create_source_registry.sql",
    "migrate:source-registry:python": "python tools/run_source_registry_migration.py",
    "migrate:corpus:publisher-null": "node scripts/run_corpus_migration.js db/migrations/corpus/20260202_source_registry_publisher_null_placeholders.sql",
    "migrate:corpus:module-source-publisher": "node scripts/run_corpus_migration.js db/migrations/corpus/20260205_source_registry_module_source_publisher_null.sql",
    "migrate:runtime:module-pending-to-unassigned": "node scripts/run_runtime_migration.js db/migrations/runtime/20260206_module_pending_to_unassigned.sql",
    "migrate:runtime:module-documents-publisher": "node scripts/run_runtime_migration.js db/migrations/runtime/20260207_module_documents_publisher.sql",
    "migrate:runtime:null-software-publishers": "node scripts/run_runtime_migration.js db/migrations/runtime/20260207_null_software_publishers_module_documents.sql",
    "migrate:runtime:plan-schemas-versioned": "node scripts/run_runtime_migration.js db/migrations/runtime/20260213_plan_schemas_versioned.sql",
    "module:report": "npx tsx tools/module_report.ts",
    "corpus:watch:general": "npx tsx tools/corpus/watch_general_corpus_ingestion.ts",
    "corpus:watch:technology": "npx tsx tools/corpus/watch_technology_corpus_ingestion.ts",
    "module:watch": "npx tsx tools/corpus/watch_module_ingestion.ts",
    "corpus:remediate-untraceables": "npx tsx tools/corpus/remediate_untraceables.ts",
    "corpus:backfill-sr-id": "npx tsx tools/corpus/backfill_source_registry_id.ts",
    "corpus:backfill-sr-titles": "npx tsx tools/corpus/backfill_source_registry_titles_from_citations.ts",
    "corpus:backfill-publisher": "npx tsx scripts/backfill_source_registry_publisher.ts",
    "corpus:backfill-module-publisher": "npx tsx tools/corpus/backfill_module_source_publisher.ts",
    "corpus:backfill-module-documents-publisher": "npx tsx tools/corpus/backfill_module_documents_publisher.ts",
    "corpus:backfill-tier": "npx tsx scripts/backfill_source_registry_tier.ts",
    "corpus:rewrite-paths": "npx tsx scripts/rewrite_corpus_document_paths.ts",
    "corpus:ensure-ingestion": "npx tsx scripts/ensure_ingestion_after_rewrite.ts",
    "rag:backfill": "python tools/rag/backfill_rag_chunks_from_document_chunks.py",
    "corpus:unfuck": "npx tsx scripts/unfuck_bad_documents.ts",
    "corpus:unfuck:dry": "npx tsx scripts/unfuck_bad_documents.ts --dry-run",
    "corpus:remove-workplace:dry": "npx tsx scripts/remove_workplace_sources.ts --dry-run",
    "corpus:remove-workplace": "npx tsx scripts/remove_workplace_sources.ts",
    "corpus:remove-by-title:dry": "npx tsx scripts/remove_sources_by_title.ts --dry-run",
    "corpus:remove-by-title": "npx tsx scripts/remove_sources_by_title.ts",
    "corpus:list-titles": "npx tsx scripts/remove_sources_by_title.ts --list",
    "build:vercel": "npx next build --webpack"
  },
  "dependencies": {
    "@types/pg": "^8.16.0",
    "@uswds/uswds": "^3.13.0",
    "next": "^16.1.6",
    "pg": "^8.16.3",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-hot-toast": "^2.6.0",
    "server-only": "^0.0.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "glob": "^11.0.0",
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.9.19",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  }
}
