# PSA Rebuild — environment template
# Copy to .env.local or .local.env and fill in values. Do not commit either file.
# Many scripts load both .env.local and .local.env (either name works).
# Placeholders only; no real credentials or secrets.
# See README.md for required vs optional variables.

# --- Required (databases) ---
# RUNTIME: assessment data, modules, OFCs, baseline. Use direct Postgres (port 5432).
RUNTIME_DATABASE_URL=postgresql://user:password@host:5432/postgres
# CORPUS: document chunks, source registry, ingestion. May use port 5432 or 6543.
CORPUS_DATABASE_URL=postgresql://user:password@host:5432/postgres

# --- Optional (app URL / API base) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Admin API protection for /api/admin/* and /api/runtime/admin/*.
# In non-development environments this should always be set.
# Send it via x-admin-api-token header or Authorization: Bearer <token> (names in app/lib/admin/constants.ts).
# ADMIN_API_TOKEN=
# Optional label written to audit logs for authenticated admin requests.
# ADMIN_API_TOKEN_LABEL=ops-admin
# Explicitly enable admin server-side tool execution from the UI.
# ENABLE_SERVER_TOOLS=0
# Legacy; some scripts may reference:
# NEXT_PUBLIC_API_BASE=http://localhost:8000

# --- Optional (Maps, if using Create Assessment location picker) ---
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Optional (Ollama — single source: app/lib/ollama/ollamaModels.ts) ---
# Set these in THIS file (psa_rebuild/.env.local). The Next.js app loads env from psa_rebuild, not the repo root.
# OLLAMA_MODELS=                        — used by the Ollama SERVER when you start it (not by this app). e.g. D:/ollamamodels. Set before running "ollama serve" or in the Ollama service config.
# PSA_OLLAMA_URL= or OLLAMA_URL or OLLAMA_HOST — e.g. http://127.0.0.1:11434 (app normalizes localhost -> 127.0.0.1).
# OLLAMA_EMBED_MODEL=nomic-embed-text:latest   — embeddings (RAG).
# PSA_METADATA_MODEL=PSA_Ollama_Model:latest   — metadata-only (publisher/title/date/synopsis/sector/subsector). Do not use for healthcheck or generation.
# PSA_GENERAL_MODEL=llama3.2:latest            — healthcheck, non-standards inference. Never point at PSA_Ollama_Model.
# Standards generation (plan/object): prefer OLLAMA_*; fallback PSA_*. Never use metadata or base llama unless explicitly set.
# OLLAMA_PLAN_STANDARD_MODEL=psa-plan-standard:latest   — PLAN standards (required_elements, criteria, evidence_examples).
# OLLAMA_OBJECT_STANDARD_MODEL=psa-object-standard:latest — OBJECT standards (required_elements, criteria, field_checks).
# PSA_PLAN_STANDARD_MODEL= / PSA_OBJECT_STANDARD_MODEL= — fallback if OLLAMA_* not set.
# PSA_OLLAMA_PLAN_MODEL= — optional override for plan structure (headings/vitals); optional OLLAMA_PLAN_VITALS_MODEL for vitals-only. Do not set to PSA_Ollama_Model.
# OLLAMA_SCOPE_TAG_MODEL=llama3.1              — scope tag analysis (if used).

# --- Optional (Python — module chunk parser, reprocess worker, scripts) ---
# PYTHON_PATH= or PYTHON= path to Python executable (e.g. C:\Python311\python.exe)
# PSA_PYTHON_PROCESSOR_EXE= full path to processor venv python (reprocess, ingestion)
# PROCESSOR_PYTHON= alternative env name used by process-incoming-pdfs
# PSA_SYSTEM_ROOT= repo root (defaults to D:\PSA_System on Windows)

# --- Optional (module / corpus storage) ---
# MODULE_SOURCES_ROOT= root for module sources (e.g. psa_rebuild/storage/module_sources). Required for Module Crawler Download/Incoming Path.
# MODULE_BLOBS_DIR= directory where module PDFs live (raw/, not pending). e.g. .../storage/module_sources/raw. Used by backfill_module_documents_publisher.
# CORPUS_SOURCES_ROOT= e.g. storage/corpus_sources (scripts, backfill)

# --- Optional (Ollama – comprehension model) ---
# Used by run_module_comprehension.ts and comprehension build. Prefer OLLAMA_*; fallback PSA_* / MODULE_*.
# OLLAMA_COMPREHENSION_MODEL=llama3.1:8b-instruct   — default (balanced, fast). Alt: qwen2.5:14b-instruct, llama3.2:latest.
# REQUIRE_MODULE_COMPREHENSION=1   — if set, standard/generate returns 503 when module_chunk_comprehension has 0 rows.
# DEBUG_MODULE_COMPREHENSION=1   — server-side diagnostics (raw output, normalized record) for first chunk only.

# --- Optional (module chunk parser timeouts) ---
# MODULE_CHUNK_PARSER_TIMEOUT_MS=600000
# MODULE_CHUNK_PARSER_MAX_CHUNKS=24
# MODULE_CHUNK_PARSER_MAX_CHARS=120000

# --- Optional (reprocess worker) ---
# REPROCESS_TIMEOUT_MS=1800000
# REPROCESS_BATCH_SIZE=10
# REPROCESS_RUN_UNTIL_EMPTY=true

# --- Optional (reference impl cache) ---
# REFERENCE_IMPL_CACHE_VERSION=v1
# REFERENCE_IMPL_CACHE_TTL_SECONDS=86400
# REFERENCE_IMPL_CACHE_DIR=storage/cache/reference_impl

# --- Optional (DB timeouts) ---
# SUPABASE_RUNTIME_CONNECT_TIMEOUT_MS=8000
# SUPABASE_RUNTIME_STATEMENT_TIMEOUT_MS=20000
# SUPABASE_RUNTIME_SSL=true
# SUPABASE_CORPUS_CONNECT_TIMEOUT_MS=15000

# --- Optional (Module Crawler at tools/module_crawler, http://localhost:4000) ---
# Required for Download / Incoming Path. Use your repo path (Windows: backslashes or forward slashes).
# MODULE_SOURCES_ROOT=D:/PSA_System/psa_rebuild/storage/module_sources
# MODULE_CRAWLER_PORT=4000
# MODULE_CRAWLER_HOST=127.0.0.1
# PSA_ADMIN_BASE_URL= e.g. http://localhost:3000 (crawler UI links to Source Registry, Modules)

# --- Optional (module ingestion watcher: watch_module_ingestion.ts) ---
# MODULE_UNASSIGNED_CODE=MODULE_UNASSIGNED (module_code for ingested-but-unassigned docs)
# CORPUS_MODULE_INCOMING= default MODULE_SOURCES_ROOT/incoming
# CORPUS_WATCHER_POLL_MS=10000
# CORPUS_WATCHER_DEBUG=1 (verbose scan logs)

# --- Optional (plan structure / vitals debugging) ---
# DEBUG_PLAN_VITALS=1 — enable server-side [plan-vitals] and SUMMARY logs (section chars, vitals count, marker/bullet presence). Run preflight once and inspect server stdout to diagnose slicing vs extractor.

# --- Optional (external services) ---
# FLASK_BASE=http://localhost:5000
# BING_API_KEY= (module research)
# SERPAPI_API_KEY= (module research)
