<Application
    x:Class="PSA.Toolbox.Launcher.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="DhsBlueBrush" Color="#005288" />
            <SolidColorBrush x:Key="DhsDarkGrayBrush" Color="#5A5B5D" />
            <SolidColorBrush x:Key="DhsLightBlueBrush" Color="#0078AE" />
            <SolidColorBrush x:Key="DhsPageBackgroundBrush" Color="#F4F5F7" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
