{
  "name": "psa-toolbox",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": "22.x"
  },
  "devDependencies": {
    "next": "16.1.6"
  },
  "scripts": {
    "sync:manifest": "node scripts/sync-toolbox-manifest.cjs",
    "verify:tools": "node scripts/verify-tool-paths.cjs",
    "install:web": "pnpm -C tools/dependency-analysis install",
    "dev": "pnpm -C tools/dependency-analysis dev",
    "build:web": "pnpm -C tools/dependency-analysis run build:web"
  }
}
