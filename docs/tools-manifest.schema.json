{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/frosty865/PSA-Toolbox/tools-manifest.schema.json",
  "title": "PSA Toolbox tools manifest",
  "type": "object",
  "required": ["version", "tools"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "tools": {
      "type": "array",
      "items": { "$ref": "#/$defs/tool" }
    }
  },
  "$defs": {
    "tool": {
      "type": "object",
      "required": ["id", "displayName", "relativePath", "description"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "displayName": { "type": "string" },
        "relativePath": { "type": "string" },
        "description": { "type": "string" },
        "readmeRelativePath": { "type": "string" },
        "start": {
          "type": "object",
          "required": ["kind", "scriptRelativePath"],
          "properties": {
            "kind": { "enum": ["powershell"] },
            "scriptRelativePath": { "type": "string" },
            "arguments": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
